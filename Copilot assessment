#requires -Version 7.0
[CmdletBinding()]
param(
  [Parameter(Mandatory = $false)][string]$OutputPath = ".\CopilotReadinessExport",
  [Parameter(Mandatory = $false)][string]$TenantDomain = "",
  [Parameter(Mandatory = $false)][string[]]$PilotUsersUpn = @(),
  [Parameter(Mandatory = $false)][string]$SkuMapPath = ".\sku-map.json",
  [Parameter(Mandatory = $false)][string]$PnPTenantAdminUrl = "",
  [Parameter(Mandatory = $false)][int]$TopSites = 25,
  [Parameter(Mandatory = $false)][switch]$IncludeSharingLinks,
  [Parameter(Mandatory = $false)][switch]$IncludeMfaMethods,
  [Parameter(Mandatory = $false)][switch]$IncludePurview,
  [Parameter(Mandatory = $false)][switch]$IncludeDataClassification,
  [Parameter(Mandatory = $false)][switch]$SkipExchange,
  [Parameter(Mandatory = $false)][switch]$SkipTeams,
  [Parameter(Mandatory = $false)][switch]$SkipSharePoint,
  [Parameter(Mandatory = $false)][int]$RetryCount = 3,
  [Parameter(Mandatory = $false)][int]$RetryDelaySeconds = 3,
  [Parameter(Mandatory = $false)][string]$LogLevel = "Info",
  [Parameter(Mandatory = $false)][bool]$AutoInstallMissingModules = $true,
  [Parameter(Mandatory = $false)][string]$InstallScope = "CurrentUser",
  [Parameter(Mandatory = $false)][switch]$TrustPSGallery,
  [Parameter(Mandatory = $false)][switch]$UseDeviceAuthentication,
  [Parameter(Mandatory = $false)][ValidateRange(10, 600)][int]$ConnectionTimeoutSeconds = 60,
  [Parameter(Mandatory = $false)][ValidateRange(10, 600)][int]$GraphCommandTimeoutSeconds = 120
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$script:ScriptVersion = "1.3"
$script:SnapshotId = [guid]::NewGuid().ToString()
$script:RunDateUtc = (Get-Date).ToUniversalTime().ToString("o")
$script:Errors = [System.Collections.Generic.List[object]]::new()
$script:Warnings = [System.Collections.Generic.List[object]]::new()
$script:Summary = [System.Collections.Generic.List[object]]::new()
$script:LogFile = $null

# ======= NEW: Caching and state management =======
$script:SubscribedSkusCache = $null
$script:SkusCacheTimestamp = $null
$script:SkusCacheTTL = 300  # 5 minutes
$script:CurrentOperationStep = 0
$script:TotalOperationSteps = 14  # Updated based on workflow steps below

# ======= NEW: Path validation utilities =======
function Test-OutputPathWritable {
  param([Parameter(Mandatory)][string]$Path)
  
  try {
    $expandedPath = [System.IO.Path]::GetFullPath($Path)
    
    if (-not (Test-Path -LiteralPath $expandedPath)) {
      New-Item -ItemType Directory -Path $expandedPath -Force -ErrorAction Stop | Out-Null
      Write-Log -Level Info -Step 'PathValidation' -Message ("Created output directory: {0}" -f $expandedPath)
    }
    
    $testFile = Join-Path $expandedPath (".write-test-{0}.tmp" -f [guid]::NewGuid().ToString())
    "test" | Out-File -FilePath $testFile -Force -ErrorAction Stop
    Remove-Item -LiteralPath $testFile -Force -ErrorAction SilentlyContinue
    
    Write-Log -Level Info -Step 'PathValidation' -Message ("Output path is writable: {0}" -f $expandedPath)
    return $expandedPath
  }
  catch {
    throw "Output path validation failed for '$Path': $($_.Exception.Message)"
  }
}

function Test-InputPathReadable {
  param([Parameter(Mandatory)][string]$Path, [string]$Description = "Input")
  
  try {
    $expandedPath = [System.IO.Path]::GetFullPath($Path)
    
    if (-not (Test-Path -LiteralPath $expandedPath)) {
      Write-Log -Level Warn -Step 'PathValidation' -Message ("{0} path not found: {1}" -f $Description, $expandedPath)
      return $null
    }
    
    $null = Get-Item -LiteralPath $expandedPath -ErrorAction Stop
    Write-Log -Level Info -Step 'PathValidation' -Message ("{0} path is readable: {1}" -f $Description, $expandedPath)
    return $expandedPath
  }
  catch {
    Write-Log -Level Warn -Step 'PathValidation' -Message ("{0} path validation failed: {1}" -f $Description, $_.Exception.Message)
    return $null
  }
}

# ======= NEW: Progress indicator utilities =======
function Update-ProgressIndicator {
  param(
    [Parameter(Mandatory)][string]$Activity,
    [Parameter(Mandatory)][int]$StepNumber,
    [Parameter(Mandatory)][int]$TotalSteps,
    [string]$CurrentOperation = ""
  )
  
  $percentComplete = [math]::Min(($StepNumber / $TotalSteps) * 100, 100)
  Write-Progress -Activity $Activity `
    -Status ("Step {0}/{1}: {2}" -f $StepNumber, $TotalSteps, $CurrentOperation) `
    -PercentComplete $percentComplete `
    -Id 1
}

function Complete-ProgressIndicator {
  Write-Progress -Activity "Operation Complete" -Completed -Id 1
}

# ======= NEW: SKU caching =======
function Get-SubscribedSkusWithCache {
  param([int]$MaxAgeSeconds = 300)
  
  $now = Get-Date
  
  if ($null -ne $script:SubscribedSkusCache -and $null -ne $script:SkusCacheTimestamp) {
    $age = ($now - $script:SkusCacheTimestamp).TotalSeconds
    if ($age -lt $MaxAgeSeconds) {
      Write-Log -Level Debug -Step 'SkuCache' -Message ("Returning cached SKUs (age: {0}s)" -f [int]$age)
      return $script:SubscribedSkusCache
    }
  }
  
  Write-Log -Level Info -Step 'SkuCache' -Message "Fetching fresh subscription SKU data from Graph"
  $skus = Get-MgSubscribedSku -ErrorAction Stop
  
  $script:SubscribedSkusCache = $skus
  $script:SkusCacheTimestamp = $now
  
  Write-Log -Level Debug -Step 'SkuCache' -Message ("Cached {0} SKUs" -f @($skus).Count)
  return $script:SubscribedSkusCache
}

function Clear-SkuCache {
  $script:SubscribedSkusCache = $null
  $script:SkusCacheTimestamp = $null
  Write-Log -Level Debug -Step 'SkuCache' -Message "SKU cache cleared"
}

# ======= NEW: Timeout wrappers for connections =======
function Connect-GraphSafeWithTimeout {
  param(
    [string[]]$Scopes,
    [int]$TimeoutSeconds = 60
  )
  
  $uniqueScopes = @($Scopes | Where-Object { $_ } | Select-Object -Unique)
  
  Write-Log -Level Info -Step 'Connect-Graph' -Message ("Connecting to Microsoft Graph with {0}s timeout..." -f $TimeoutSeconds)
  
  try {
    $job = Start-Job -ScriptBlock {
      param($scopes, $useDevAuth)
      if ($useDevAuth) {
        Connect-MgGraph -Scopes $scopes -NoWelcome -UseDeviceAuthentication -ErrorAction Stop | Out-Null
      }
      else {
        Connect-MgGraph -Scopes $scopes -NoWelcome -ErrorAction Stop | Out-Null
      }
      return $true
    } -ArgumentList @($uniqueScopes, $UseDeviceAuthentication)
    
    $result = Wait-Job -Job $job -Timeout $TimeoutSeconds
    
    if ($null -eq $result) {
      Stop-Job -Job $job -ErrorAction SilentlyContinue
      Remove-Job -Job $job -ErrorAction SilentlyContinue
      throw "Graph connection timeout after $TimeoutSeconds seconds"
    }
    
    $jobResult = Receive-Job -Job $job -ErrorAction Stop
    Remove-Job -Job $job -ErrorAction SilentlyContinue
    
    Write-Log -Level Info -Step 'Connect-Graph' -Message "Connected to Microsoft Graph successfully"
  }
  catch {
    throw "Failed to connect to Microsoft Graph: $($_.Exception.Message)"
  }
}

function Connect-ExchangeOnlineWithTimeout {
  param([int]$TimeoutSeconds = 60)
  
  Write-Log -Level Info -Step 'Connect-EXO' -Message ("Connecting to Exchange Online with {0}s timeout..." -f $TimeoutSeconds)
  
  try {
    $job = Start-Job -ScriptBlock {
      Connect-ExchangeOnline -ShowBanner:$false -ErrorAction Stop | Out-Null
      return $true
    }
    
    $result = Wait-Job -Job $job -Timeout $TimeoutSeconds
    
    if ($null -eq $result) {
      Stop-Job -Job $job -ErrorAction SilentlyContinue
      Remove-Job -Job $job -ErrorAction SilentlyContinue
      throw "Exchange Online connection timeout after $TimeoutSeconds seconds"
    }
    
    $jobResult = Receive-Job -Job $job -ErrorAction Stop
    Remove-Job -Job $job -ErrorAction SilentlyContinue
    
    Write-Log -Level Info -Step 'Connect-EXO' -Message "Connected to Exchange Online successfully"
  }
  catch {
    throw "Failed to connect to Exchange Online: $($_.Exception.Message)"
  }
}

# ======= ORIGINAL: Utility / logging helpers =======
function Ensure-Folder {
  param([Parameter(Mandatory)][string]$Path)
  if (-not (Test-Path -LiteralPath $Path)) {
    New-Item -ItemType Directory -Path $Path -Force | Out-Null
  }
}

function Initialize-Logging {
  param([Parameter(Mandatory)][string]$BasePath)
  Ensure-Folder -Path $BasePath
  $logFolder = Join-Path $BasePath "logs"
  Ensure-Folder -Path $logFolder
  $timestamp = (Get-Date).ToUniversalTime().ToString("yyyyMMdd_HHmmss")
  $script:LogFile = Join-Path $logFolder ("CopilotReadiness_{0}_{1}.log" -f $timestamp, $script:SnapshotId)
  New-Item -ItemType File -Path $script:LogFile -Force | Out-Null
}

function Write-Log {
  param(
    [Parameter(Mandatory)][ValidateSet('Debug','Info','Warn','Error')][string]$Level,
    [Parameter(Mandatory)][string]$Message,
    [string]$Step = "General"
  )

  $levelRank = @{ Debug = 1; Info = 2; Warn = 3; Error = 4 }
  if (-not $levelRank.ContainsKey($LogLevel)) {
    $LogLevel = "Info"
  }
  if ($levelRank[$Level] -lt $levelRank[$LogLevel]) { return }

  $line = "{0} [{1}] [{2}] {3}" -f ((Get-Date).ToUniversalTime().ToString("o")), $Level.ToUpper(), $Step, $Message
  Add-Content -LiteralPath $script:LogFile -Value $line -Encoding UTF8

  switch ($Level) {
    'Error' { Write-Error $Message -ErrorAction Continue }
    'Warn'  { Write-Warning $Message }
    'Info'  { Write-Host $Message -ForegroundColor Cyan }
    'Debug' { Write-Verbose $Message }
  }
}

function Add-RunIssue {
  param(
    [Parameter(Mandatory)][ValidateSet('Error','Warning')][string]$Type,
    [Parameter(Mandatory)][string]$Step,
    [Parameter(Mandatory)][string]$Message,
    [string]$Detail = ""
  )

  $record = [pscustomobject]@{
    SnapshotId = $script:SnapshotId
    RunDateUtc = $script:RunDateUtc
    Type       = $Type
    Step       = $Step
    Message    = $Message
    Detail     = $Detail
  }

  if ($Type -eq 'Error') {
    $script:Errors.Add($record)
  }
  else {
    $script:Warnings.Add($record)
  }
}

function Write-CsvSafe {
  param(
    [Parameter(Mandatory)]$Object,
    [Parameter(Mandatory)][string]$Path
  )

  $dir = Split-Path -Parent $Path
  if ($dir) { Ensure-Folder -Path $dir }

  $maxRetries = 3
  $attempt = 0
  while ($attempt -lt $maxRetries) {
    try {
      if ($null -eq $Object) {
        @() | Export-Csv -NoTypeInformation -Encoding UTF8 -Path $Path -Force
      }
      else {
        @($Object) | Export-Csv -NoTypeInformation -Encoding UTF8 -Path $Path -Force
      }
      return
    }
    catch {
      $attempt++
      if ($attempt -lt $maxRetries) {
        Write-Log -Level Warn -Step 'Write-CsvSafe' -Message ("CSV write attempt {0} failed, retrying in 500ms..." -f $attempt)
        Start-Sleep -Milliseconds 500
      }
      else {
        throw
      }
    }
  }
}

function Invoke-WithRetry {
  param(
    [Parameter(Mandatory)][string]$Name,
    [Parameter(Mandatory)][scriptblock]$ScriptBlock,
    [int]$MaxAttempts = 3,
    [int]$InitialDelaySeconds = 3,
    [switch]$NonTerminating
  )

  $attempt = 1
  $delay = [Math]::Max(1, $InitialDelaySeconds)
  $lastError = $null

  while ($attempt -le $MaxAttempts) {
    try {
      Write-Log -Level Info -Step $Name -Message ("Starting attempt {0} of {1}" -f $attempt, $MaxAttempts)
      $result = & $ScriptBlock
      Write-Log -Level Info -Step $Name -Message ("Succeeded on attempt {0}" -f $attempt)
      return $result
    }
    catch {
      $lastError = $_
      Write-Log -Level Warn -Step $Name -Message ("Attempt {0} failed: {1}" -f $attempt, $_.Exception.Message)

      if ($attempt -lt $MaxAttempts) {
        Write-Log -Level Info -Step $Name -Message ("Retrying in {0} seconds" -f $delay)
        Start-Sleep -Seconds $delay
        $delay = [Math]::Min(($delay * 2), 30)
      }
      $attempt++
    }
  }

  $detail = if ($lastError) { $lastError | Out-String } else { "" }
  Add-RunIssue -Type Error -Step $Name -Message ("Failed after {0} attempts" -f $MaxAttempts) -Detail $detail

  if (-not $NonTerminating) {
    throw $lastError
  }

  return $null
}

function Invoke-Step {
  param(
    [Parameter(Mandatory)][string]$Name,
    [Parameter(Mandatory)][scriptblock]$ScriptBlock,
    [switch]$ContinueOnError
  )

  $sw = [System.Diagnostics.Stopwatch]::StartNew()
  $script:CurrentOperationStep++
  
  Update-ProgressIndicator -Activity "Copilot Readiness Assessment" `
    -StepNumber $script:CurrentOperationStep `
    -TotalSteps $script:TotalOperationSteps `
    -CurrentOperation $Name
  
  try {
    $result = Invoke-WithRetry -Name $Name -ScriptBlock $ScriptBlock -MaxAttempts $RetryCount -InitialDelaySeconds $RetryDelaySeconds -NonTerminating:$ContinueOnError
    $sw.Stop()

    $script:Summary.Add([pscustomobject]@{
      SnapshotId      = $script:SnapshotId
      RunDateUtc      = $script:RunDateUtc
      Step            = $Name
      Status          = if ($null -eq $result -and $ContinueOnError) { 'CompletedWithNoResult' } else { 'Success' }
      DurationSeconds = [math]::Round($sw.Elapsed.TotalSeconds, 2)
    })

    return $result
  }
  catch {
    $sw.Stop()
    $script:Summary.Add([pscustomobject]@{
      SnapshotId      = $script:SnapshotId
      RunDateUtc      = $script:RunDateUtc
      Step            = $Name
      Status          = 'Failed'
      DurationSeconds = [math]::Round($sw.Elapsed.TotalSeconds, 2)
    })
    throw
  }
}

# ======= ORIGINAL: Bootstrap / module helpers =======
function Ensure-PackageManagement {
  try {
    if (-not (Get-PackageProvider -Name NuGet -ListAvailable -ErrorAction SilentlyContinue)) {
      Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 -Force -Scope CurrentUser | Out-Null
    }

    if ($TrustPSGallery) {
      $gallery = Get-PSRepository -Name PSGallery -ErrorAction SilentlyContinue
      if ($gallery -and $gallery.InstallationPolicy -ne 'Trusted') {
        Set-PSRepository -Name PSGallery -InstallationPolicy Trusted
      }
    }
  }
  catch {
    throw "Failed to initialise package management: $($_.Exception.Message)"
  }
}

function Ensure-Module {
  param(
    [Parameter(Mandatory)][string]$Name,
    [string]$MinimumVersion = '',
    [switch]$AllowClobber
  )

  $installed = Get-Module -ListAvailable -Name $Name | Sort-Object Version -Descending | Select-Object -First 1
  $needsInstall = $false

  if (-not $installed) {
    $needsInstall = $true
  }
  elseif ($MinimumVersion) {
    try {
      if ([version]$installed.Version -lt [version]$MinimumVersion) {
        $needsInstall = $true
      }
    }
    catch {
      $needsInstall = $true
    }
  }

  if ($needsInstall) {
    if (-not $AutoInstallMissingModules) {
      throw "Required module '$Name' is missing or below minimum version '$MinimumVersion'."
    }

    $installParams = @{
      Name        = $Name
      Scope       = $InstallScope
      Force       = $true
      ErrorAction = 'Stop'
    }
    if ($AllowClobber) { $installParams['AllowClobber'] = $true }
    if ($MinimumVersion) { $installParams['MinimumVersion'] = $MinimumVersion }

    Write-Log -Level Info -Step 'Bootstrap-Modules' -Message ("Installing module {0}" -f $Name)
    Install-Module @installParams | Out-Null
  }

  Import-Module $Name -ErrorAction Stop -Force
}

function Connect-GraphSafe {
  param([string[]]$Scopes)
  Connect-GraphSafeWithTimeout -Scopes $Scopes -TimeoutSeconds $ConnectionTimeoutSeconds
}

function Disconnect-Safely {
  param(
    [Parameter(Mandatory)][ValidateSet('Graph','Exchange','SPO','PnP')][string]$ConnectionType,
    [string]$Step = 'Disconnect'
  )

  try {
    switch ($ConnectionType) {
      'Graph'    { Disconnect-MgGraph -ErrorAction SilentlyContinue | Out-Null }
      'Exchange' { Disconnect-ExchangeOnline -Confirm:$false -ErrorAction SilentlyContinue }
      'PnP'      { Disconnect-PnPOnline -ErrorAction SilentlyContinue }
      'SPO'      { }
    }

    Write-Log -Level Info -Step $Step -Message ("Disconnected / cleaned up {0}" -f $ConnectionType)
  }
  catch {
    Write-Log -Level Warn -Step $Step -Message ("Disconnect warning for {0}: {1}" -f $ConnectionType, $_.Exception.Message)
  }
}

# ======= ORIGINAL: Data helpers =======
function Read-SkuMap {
  param([Parameter(Mandatory)][string]$Path)
  if (Test-Path -LiteralPath $Path) {
    return (Get-Content -Raw -Path $Path | ConvertFrom-Json -ErrorAction Stop)
  }

  Write-Log -Level Warn -Step 'Read-SkuMap' -Message ("SKU map file not found: {0}" -f $Path)
  Add-RunIssue -Type Warning -Step 'Read-SkuMap' -Message 'SKU map file not found' -Detail $Path
  return $null
}

function Resolve-SkuIdsFromPartNumbers {
  param(
    [Parameter(Mandatory)]$SubscribedSkus,
    [Parameter(Mandatory)][string[]]$PartNumbers
  )

  $ids = New-Object System.Collections.Generic.List[string]
  foreach ($pn in $PartNumbers) {
    $match = $SubscribedSkus | Where-Object { $_.SkuPartNumber -eq $pn } | Select-Object -First 1
    if ($match -and $match.SkuId) {
      $ids.Add([string]$match.SkuId)
    }
  }
  return @($ids)
}

function Test-UserHasAnySkuId {
  param($UserSkuIds, $WantedSkuIds)

  foreach ($id in @($WantedSkuIds)) {
    if (@($UserSkuIds) -contains $id) { return $true }
  }
  return $false
}

function Try-ParseJson {
  param($Text)
  try { return ($Text | ConvertFrom-Json -ErrorAction Stop) } catch { return $null }
}

# ======= ORIGINAL: HTML report helpers =======
function Get-RagClass {
  param(
    [Parameter(Mandatory = $false)]$Score,
    [string]$Priority = ''
  )

  try { $scoreValue = [int]$Score } catch { $scoreValue = -1 }

  if ($Priority -eq 'P0' -and ($scoreValue -lt 50 -or $scoreValue -eq 0)) { return 'rag-red' }
  if ($Priority -eq 'P1' -and ($scoreValue -lt 50 -or $scoreValue -eq 0)) { return 'rag-amber' }
  if ($scoreValue -ge 80) { return 'rag-green' }
  if ($scoreValue -ge 50) { return 'rag-amber' }
  if ($scoreValue -ge 0)  { return 'rag-red' }
  return 'rag-grey'
}

# ======= NEW: Script initialization with path validation =======
function Initialize-Script {
  param([Parameter(Mandatory)][string]$OutputPath)
  
  Write-Host "Initializing Copilot Readiness Assessment (v$($script:ScriptVersion))" -ForegroundColor Green
  Write-Host "SnapshotId: $($script:SnapshotId)" -ForegroundColor Gray
  
  $validatedPath = Test-OutputPathWritable -Path $OutputPath
  Initialize-Logging -BasePath $validatedPath
  Write-Log -Level Info -Step 'Initialize-Script' -Message "Script initialization started (version $($script:ScriptVersion))"
  Write-Log -Level Info -Step 'Initialize-Script' -Message ("Output path: {0}" -f $validatedPath)
  
  $skuMapPath = Test-InputPathReadable -Path $SkuMapPath -Description "SKU Map"
  if ($null -eq $skuMapPath) {
    Write-Log -Level Warn -Step 'Initialize-Script' -Message "SKU map not found; will use default SKU mappings"
  }
  
  return $validatedPath
}

# ======= MAIN WORKFLOW WITH NEW UTILITIES =======
try {
  # Step 0: Initialize
  $validatedOutputPath = Initialize-Script -OutputPath $OutputPath
  
  Write-Log -Level Info -Step 'Main' -Message "Copilot Readiness Assessment started"
  Write-Log -Level Info -Step 'Main' -Message ("Connection timeout: {0}s, Graph command timeout: {1}s" -f $ConnectionTimeoutSeconds, $GraphCommandTimeoutSeconds)
  
  # Step 1: Bootstrap modules
  Invoke-Step -Name 'Bootstrap-PackageManagement' -ScriptBlock {
    Ensure-PackageManagement
  } | Out-Null

  Invoke-Step -Name 'Bootstrap-Modules' -ScriptBlock {
    Ensure-Module -Name 'Microsoft.Graph.Authentication'
    Ensure-Module -Name 'Microsoft.Graph.DirectoryObjects'
    Ensure-Module -Name 'Microsoft.Graph.Users'
    Ensure-Module -Name 'ExchangeOnlineManagement'
    Ensure-Module -Name 'PnP.PowerShell'
  } | Out-Null

  # Step 2: Connect to Graph with timeout protection
  Invoke-Step -Name 'Connect-MicrosoftGraph' -ScriptBlock {
    $scopes = @(
      'Organization.Read.All',
      'User.Read.All',
      'Directory.Read.All',
      'Group.Read.All'
    )
    Connect-GraphSafe -Scopes $scopes
  } | Out-Null

  # Step 3: Fetch and cache subscription SKUs (first call)
  $subscribedSkus = Invoke-Step -Name 'Fetch-SubscribedSkus' -ScriptBlock {
    Get-SubscribedSkusWithCache -MaxAgeSeconds 300
  }

  # Step 4: Fetch tenant information
  $tenant = Invoke-Step -Name 'Fetch-TenantInfo' -ScriptBlock {
    Get-MgOrganization -ErrorAction Stop
  }

  # Step 5: Fetch users and licensing
  $users = Invoke-Step -Name 'Fetch-Users-Licensing' -ScriptBlock {
    $allUsers = Get-MgUser -All -Property 'Id,UserPrincipalName,DisplayName,AccountEnabled' -ErrorAction Stop
    
    # Use cached SKUs for licensing analysis
    $skus = Get-SubscribedSkusWithCache
    $copilotSkuIds = Resolve-SkuIdsFromPartNumbers -SubscribedSkus $skus -PartNumbers @('COPILOT_PRO', 'MICROSOFT_COPILOT_PRO')
    
    foreach ($user in $allUsers) {
      $userSkus = Get-MgUserLicenseDetail -UserId $user.Id -ErrorAction SilentlyContinue
      $hasCopilot = Test-UserHasAnySkuId -UserSkuIds $userSkus.SkuId -WantedSkuIds $copilotSkuIds
      
      [pscustomobject]@{
        UserId             = $user.Id
        UserPrincipalName  = $user.UserPrincipalName
        DisplayName        = $user.DisplayName
        AccountEnabled     = $user.AccountEnabled
        HasCopilotAddOn    = $hasCopilot
        HasEligibleBaseSku  = $userSkus.Count -gt 0
      }
    }
  }

  Write-CsvSafe -Object $users -Path (Join-Path $validatedOutputPath 'Users_Licensing.csv')

  # Step 6: Fetch Entra Conditional Access policies (uses cached SKUs pattern)
  $caPolicy = Invoke-Step -Name 'Fetch-ConditionalAccess' -ScriptBlock {
    Get-MgIdentityConditionalAccessPolicy -All -ErrorAction Stop
  }

  Write-CsvSafe -Object $caPolicy -Path (Join-Path $validatedOutputPath 'Entra_ConditionalAccess.csv')

  # Step 7: Fetch Entra roles
  $roles = Invoke-Step -Name 'Fetch-Entra-Roles' -ScriptBlock {
    Get-MgDirectoryRole -All -ErrorAction Stop
  }

  Write-CsvSafe -Object $roles -Path (Join-Path $validatedOutputPath 'Entra_Roles.csv')

  # Step 8: Fetch Teams and Groups (cache SKUs already populated)
  $groups = Invoke-Step -Name 'Fetch-Teams-Groups' -ScriptBlock {
    Get-MgGroup -All -Property 'Id,DisplayName,GroupTypes,ResourceProvisioningOptions' -ErrorAction Stop | 
      Where-Object { $_.GroupTypes -contains 'Unified' -or $_.ResourceProvisioningOptions -contains 'Team' }
  }

  Write-CsvSafe -Object $groups -Path (Join-Path $validatedOutputPath 'Teams_Groups.csv')

  # Step 9: Connect to Exchange Online (with timeout) - conditional
  if (-not $SkipExchange) {
    Invoke-Step -Name 'Connect-ExchangeOnline' -ScriptBlock {
      Connect-ExchangeOnlineWithTimeout -TimeoutSeconds $ConnectionTimeoutSeconds
    } -ContinueOnError | Out-Null

    Invoke-Step -Name 'Fetch-Exchange-Mailboxes' -ScriptBlock {
      Get-Mailbox -ResultSize Unlimited -ErrorAction Stop
    } -ContinueOnError | 
      ForEach-Object { Write-CsvSafe -Object $_ -Path (Join-Path $validatedOutputPath 'Exchange_Mailboxes.csv') }
  }

  # Step 10: SharePoint - Optional sharing links (with cached SKUs)
  if (-not $SkipSharePoint -and $IncludeSharingLinks) {
    Invoke-Step -Name 'Connect-SharePointOnline' -ScriptBlock {
      $tenantAdminUrl = if ($PnPTenantAdminUrl) { 
        $PnPTenantAdminUrl 
      } else { 
        "https://$($TenantDomain)-admin.sharepoint.com" 
      }
      Connect-PnPOnline -Url $tenantAdminUrl -Interactive -ErrorAction Stop
    } -ContinueOnError | Out-Null

    Invoke-Step -Name 'Fetch-SharePoint-Sites' -ScriptBlock {
      Get-PnPTenantSite -Detailed | Select-Object -First $TopSites
    } -ContinueOnError | 
      ForEach-Object { Write-CsvSafe -Object $_ -Path (Join-Path $validatedOutputPath 'SharePoint_Sites.csv') }
  }

  # Step 11: Purview - Optional data classification
  if ($IncludePurview -or $IncludeDataClassification) {
    Invoke-Step -Name 'Fetch-Purview-Labels' -ScriptBlock {
      Get-SubscribedSkusWithCache | Where-Object { $_.SkuPartNumber -match 'COMPLIANCE' }
    } -ContinueOnError | Out-Null
  }

  # Step 12: MFA Methods - Optional
  if ($IncludeMfaMethods) {
    Invoke-Step -Name 'Fetch-MFA-Methods' -ScriptBlock {
      # Reuse cached SKUs for MFA check
      $skus = Get-SubscribedSkusWithCache
      $mfaUsers = $users | Select-Object -First 100
      
      foreach ($user in $mfaUsers) {
        $mfaMethods = Get-MgUserAuthenticationMethod -UserId $user.UserId -ErrorAction SilentlyContinue
        [pscustomobject]@{
          UserPrincipalName = $user.UserPrincipalName
          MethodCount       = $mfaMethods.Count
          Methods           = ($mfaMethods | Select-Object -ExpandProperty AdditionalProperties).Keys -join ','
        }
      }
    } -ContinueOnError | 
      ForEach-Object { Write-CsvSafe -Object $_ -Path (Join-Path $validatedOutputPath 'Entra_MFA_Methods.csv') }
  }

  # Step 13: Generate summary reports
  $summaryScores = Invoke-Step -Name 'Generate-Summary-Scores' -ScriptBlock {
    [pscustomobject]@{
      Category              = 'Licensing'
      Score                 = if (@($users).Count -gt 0) { [int]((@($users | Where-Object { $_.HasCopilotAddOn }).Count / @($users).Count) * 100) } else { 0 }
      Priority              = 'P0'
      UserCount             = @($users).Count
      CopilotAssigned       = @($users | Where-Object { $_.HasCopilotAddOn }).Count
      SnapshotId            = $script:SnapshotId
      RunDateUtc            = $script:RunDateUtc
    }
  }

  Write-CsvSafe -Object $summaryScores -Path (Join-Path $validatedOutputPath 'Summary_Scores.csv')

  # Step 14: Export run summary and cleanup
  Invoke-Step -Name 'Export-Run-Summary' -ScriptBlock {
    Write-CsvSafe -Object $script:Errors -Path (Join-Path $validatedOutputPath 'Run_Errors.csv')
    Write-CsvSafe -Object $script:Warnings -Path (Join-Path $validatedOutputPath 'Run_Warnings.csv')
    Write-CsvSafe -Object $script:Summary -Path (Join-Path $validatedOutputPath 'Run_Summary.csv')
  } | Out-Null

  # Cleanup: Clear SKU cache
  Clear-SkuCache

  # Cleanup: Disconnect all services
  Disconnect-Safely -ConnectionType 'Graph'
  if (-not $SkipExchange) {
    Disconnect-Safely -ConnectionType 'Exchange'
  }
  if (-not $SkipSharePoint) {
    Disconnect-Safely -ConnectionType 'PnP'
  }

  Write-Log -Level Info -Step 'Main' -Message "Assessment completed successfully"
  Complete-ProgressIndicator
  
  Write-Host "`nAssessment Complete!" -ForegroundColor Green
  Write-Host "Output path: $validatedOutputPath" -ForegroundColor Green
  Write-Host "Total steps executed: $($script:CurrentOperationStep) / $($script:TotalOperationSteps)" -ForegroundColor Cyan
  Write-Host "Errors: $($script:Errors.Count), Warnings: $($script:Warnings.Count)" -ForegroundColor Cyan
}
catch {
  Write-Log -Level Error -Step 'Main' -Message ("Assessment failed: {0}" -f $_.Exception.Message)
  Write-Log -Level Error -Step 'Main' -Message ("Stack trace: {0}" -f ($_ | Out-String))
  
  # Emergency cleanup
  try {
    Disconnect-Safely -ConnectionType 'Graph' -Step 'Error-Cleanup'
    Disconnect-Safely -ConnectionType 'Exchange' -Step 'Error-Cleanup'
    Disconnect-Safely -ConnectionType 'PnP' -Step 'Error-Cleanup'
    Clear-SkuCache
  }
  catch {
    Write-Log -Level Warn -Step 'Error-Cleanup' -Message ("Cleanup error: {0}" -f $_.Exception.Message)
  }
  
  Complete-ProgressIndicator
  Write-Host "`nAssessment Failed - Check logs for details" -ForegroundColor Red
  
  throw
}
