#requires -Version 7.0
param(
  [Parameter(Mandatory=$false)][string]$OutputPath = ".\CopilotReadinessExport",
  [Parameter(Mandatory=$false)][string]$TenantDomain = "",
  [Parameter(Mandatory=$false)][string[]]$PilotUsersUpn = @(),
  [Parameter(Mandatory=$false)][string]$SkuMapPath = ".\sku-map.json",
  [Parameter(Mandatory=$false)][string]$PnPTenantAdminUrl = "",
  [Parameter(Mandatory=$false)][int]$TopSites = 25,
  [Parameter(Mandatory=$false)][switch]$IncludeSharingLinks,
  [Parameter(Mandatory=$false)][switch]$IncludeMfaMethods,
  [Parameter(Mandatory=$false)][switch]$IncludePurview,
  [Parameter(Mandatory=$false)][switch]$IncludeDataClassification,
  [Parameter(Mandatory=$false)][switch]$SkipExchange,
  [Parameter(Mandatory=$false)][switch]$SkipTeams,
  [Parameter(Mandatory=$false)][switch]$SkipSharePoint
)

$ErrorActionPreference = "Stop"
$scriptVersion = "0.3"

function New-SnapshotId { return ([Guid]::NewGuid()).ToString() }
function Ensure-Folder([string]$Path){ if(-not (Test-Path $Path)){ New-Item -ItemType Directory -Path $Path | Out-Null } }
function Write-Csv($Object, [string]$Path){ $Object | Export-Csv -NoTypeInformation -Encoding UTF8 -Path $Path }
function Try-Run([string]$Name, [scriptblock]$Block){
  try { & $Block; return $null } catch { return [pscustomobject]@{ Step=$Name; Error=$_.Exception.Message } }
}

function Read-SkuMap([string]$Path){
  if(Test-Path $Path){ return (Get-Content -Raw -Path $Path | ConvertFrom-Json) }
  return $null
}

function Resolve-SkuIdsFromPartNumbers($subscribedSkus, [string[]]$partNumbers){
  $ids = @()
  foreach($pn in $partNumbers){
    $match = $subscribedSkus | Where-Object { $_.SkuPartNumber -eq $pn } | Select-Object -First 1
    if($match){ $ids += $match.SkuId }
  }
  return $ids
}

function Test-UserHasAnySkuId($userSkuIds, $wantedSkuIds){
  foreach($id in $wantedSkuIds){ if($userSkuIds -contains $id){ return $true } }
  return $false
}

function Try-ParseJson($text){
  try { return ($text | ConvertFrom-Json -ErrorAction Stop) } catch { return $null }
}

Ensure-Folder $OutputPath
$snapshotId = New-SnapshotId
$runDateUtc = (Get-Date).ToUniversalTime().ToString("o")
$errors = @()

# -------------------------------
# 1) Microsoft Graph (core)
# -------------------------------
$errors += Try-Run "Connect-MgGraph" {
  Import-Module Microsoft.Graph -ErrorAction Stop
  $scopes = @("Organization.Read.All","User.Read.All","Directory.Read.All","Policy.Read.All","Group.Read.All","LicenseAssignment.Read.All")
  if($IncludeMfaMethods){ $scopes += "UserAuthenticationMethod.Read.All" }
  Connect-MgGraph -Scopes ($scopes | Select-Object -Unique) | Out-Null
}

$org = $null
$errors += Try-Run "Get-Org" { $org = Get-MgOrganization -Property Id,DisplayName,VerifiedDomains }
$tenantId = $org.Id
if([string]::IsNullOrWhiteSpace($TenantDomain)){ $TenantDomain = ($org.VerifiedDomains | Where-Object {$_.IsDefault -eq $true} | Select-Object -First 1).Name }

$snapshot = [pscustomobject]@{ SnapshotId=$snapshotId; TenantId=$tenantId; TenantDomain=$TenantDomain; TenantName=$org.DisplayName; RunDateUtc=$runDateUtc; ScriptVersion=$scriptVersion }
Write-Csv @($snapshot) (Join-Path $OutputPath "TenantSnapshot.csv")

# -------------------------------
# 2) Licensing (via sku-map.json + Graph)
# -------------------------------
$skuMap = Read-SkuMap $SkuMapPath
$subscribedSkus = @()
$errors += Try-Run "Get-SubscribedSkus" { $subscribedSkus = Get-MgSubscribedSku -All }

$eligibleBaseSkuIds = @(); $copilotSkuIds = @()
if($skuMap){
  $eligibleBaseSkuIds = Resolve-SkuIdsFromPartNumbers $subscribedSkus $skuMap.EligibleBaseSkuPartNumbers
  $copilotSkuIds = Resolve-SkuIdsFromPartNumbers $subscribedSkus $skuMap.CopilotSkuPartNumbers
}

$users = @()
$errors += Try-Run "Get-Users" { $users = Get-MgUser -All -Property Id,DisplayName,UserPrincipalName,AccountEnabled,UserType }
if($PilotUsersUpn.Count -gt 0){ $users = $users | Where-Object { $PilotUsersUpn -contains $_.UserPrincipalName } }

$userRows = @()
$errors += Try-Run "Get-UserLicenseDetail" {
  foreach($u in $users){
    $licenseDetail = Get-MgUserLicenseDetail -UserId $u.Id -ErrorAction Stop
    $userSkuIds = @($licenseDetail | Select-Object -ExpandProperty SkuId)
    $hasEligibleBase = if($skuMap){ Test-UserHasAnySkuId $userSkuIds $eligibleBaseSkuIds } else { $null }
    $hasCopilot = if($skuMap){ Test-UserHasAnySkuId $userSkuIds $copilotSkuIds } else { $null }
    $userRows += [pscustomobject]@{
      SnapshotId=$snapshotId; UserPrincipalName=$u.UserPrincipalName; DisplayName=$u.DisplayName; AccountEnabled=$u.AccountEnabled; UserType=$u.UserType;
      AssignedSkuPartNumbers=($licenseDetail.SkuPartNumber -join "|");
      HasEligibleBaseSku= if($skuMap){ [bool]$hasEligibleBase } else { "Unknown" };
      HasCopilotAddOn= if($skuMap){ [bool]$hasCopilot } else { "Unknown" }
    }
  }
}
Write-Csv $userRows (Join-Path $OutputPath "Users_Licensing.csv")

# -------------------------------
# 3) Conditional Access policies
# -------------------------------
$ca = @(); $errors += Try-Run "Get-ConditionalAccess" { $ca = Get-MgIdentityConditionalAccessPolicy -All }
$caRows = foreach($p in $ca){ [pscustomobject]@{ SnapshotId=$snapshotId; PolicyId=$p.Id; Name=$p.DisplayName; State=$p.State; Created=$p.CreatedDateTime; Modified=$p.ModifiedDateTime } }
Write-Csv $caRows (Join-Path $OutputPath "Entra_ConditionalAccess.csv")

# -------------------------------
# 4) Directory role assignments
# -------------------------------
$roles = @(); $errors += Try-Run "Get-DirectoryRoles" { $roles = Get-MgDirectoryRole -All }
$roleAssignments = @();
$errors += Try-Run "Get-RoleAssignments" {
