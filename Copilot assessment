#requires -Version 7.0
[CmdletBinding()]
param(
  [Parameter(Mandatory = $false)][string]$OutputPath = ".\CopilotReadinessExport",
  [Parameter(Mandatory = $false)][string]$TenantDomain = "",
  [Parameter(Mandatory = $false)][string[]]$PilotUsersUpn = @(),
  [Parameter(Mandatory = $false)][string]$SkuMapPath = ".\sku-map.json",
  [Parameter(Mandatory = $false)][string]$PnPTenantAdminUrl = "",
  [Parameter(Mandatory = $false)][int]$TopSites = 25,
  [Parameter(Mandatory = $false)][switch]$IncludeSharingLinks,
  [Parameter(Mandatory = $false)][switch]$IncludeMfaMethods,
  [Parameter(Mandatory = $false)][switch]$IncludePurview,
  [Parameter(Mandatory = $false)][switch]$IncludeDataClassification,
  [Parameter(Mandatory = $false)][switch]$SkipExchange,
  [Parameter(Mandatory = $false)][switch]$SkipTeams,
  [Parameter(Mandatory = $false)][switch]$SkipSharePoint,
  [Parameter(Mandatory = $false)][int]$RetryCount = 3,
  [Parameter(Mandatory = $false)][int]$RetryDelaySeconds = 3,
  [Parameter(Mandatory = $false)][string]$LogLevel = "Info",
  [Parameter(Mandatory = $false)][bool]$AutoInstallMissingModules = $true,
  [Parameter(Mandatory = $false)][string]$InstallScope = "CurrentUser",
  [Parameter(Mandatory = $false)][switch]$TrustPSGallery,
  [Parameter(Mandatory = $false)][switch]$UseDeviceAuthentication
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$script:ScriptVersion = "1.2"
$script:SnapshotId = [guid]::NewGuid().ToString()
$script:RunDateUtc = (Get-Date).ToUniversalTime().ToString("o")
$script:Errors = [System.Collections.Generic.List[object]]::new()
$script:Warnings = [System.Collections.Generic.List[object]]::new()
$script:Summary = [System.Collections.Generic.List[object]]::new()
$script:LogFile = $null

# -------------------------------
# Utility / logging helpers
# -------------------------------
function Ensure-Folder {
  param([Parameter(Mandatory)][string]$Path)
  if (-not (Test-Path -LiteralPath $Path)) {
    New-Item -ItemType Directory -Path $Path -Force | Out-Null
  }
}

function Initialize-Logging {
  param([Parameter(Mandatory)][string]$BasePath)
  Ensure-Folder -Path $BasePath
  $logFolder = Join-Path $BasePath "logs"
  Ensure-Folder -Path $logFolder
  $timestamp = (Get-Date).ToUniversalTime().ToString("yyyyMMdd_HHmmss")
  $script:LogFile = Join-Path $logFolder ("CopilotReadiness_{0}_{1}.log" -f $timestamp, $script:SnapshotId)
  New-Item -ItemType File -Path $script:LogFile -Force | Out-Null
}

function Write-Log {
  param(
    [Parameter(Mandatory)][ValidateSet('Debug','Info','Warn','Error')][string]$Level,
    [Parameter(Mandatory)][string]$Message,
    [string]$Step = "General"
  )

  $levelRank = @{ Debug = 1; Info = 2; Warn = 3; Error = 4 }
  if ($levelRank[$Level] -lt $levelRank[$LogLevel]) { return }

  $line = "{0} [{1}] [{2}] {3}" -f ((Get-Date).ToUniversalTime().ToString("o")), $Level.ToUpper(), $Step, $Message
  Add-Content -LiteralPath $script:LogFile -Value $line -Encoding UTF8

  switch ($Level) {
    'Error' { Write-Error $Message -ErrorAction Continue }
    'Warn'  { Write-Warning $Message }
    'Info'  { Write-Host $Message -ForegroundColor Cyan }
    'Debug' { Write-Verbose $Message }
  }
}

function Add-RunIssue {
  param(
    [Parameter(Mandatory)][ValidateSet('Error','Warning')][string]$Type,
    [Parameter(Mandatory)][string]$Step,
    [Parameter(Mandatory)][string]$Message,
    [string]$Detail = ""
  )

  $record = [pscustomobject]@{
    SnapshotId = $script:SnapshotId
    RunDateUtc = $script:RunDateUtc
    Type       = $Type
    Step       = $Step
    Message    = $Message
    Detail     = $Detail
  }

  if ($Type -eq 'Error') {
    $script:Errors.Add($record)
  }
  else {
    $script:Warnings.Add($record)
  }
}

function Write-CsvSafe {
  param(
    [Parameter(Mandatory)]$Object,
    [Parameter(Mandatory)][string]$Path
  )

  $dir = Split-Path -Parent $Path
  if ($dir) { Ensure-Folder -Path $dir }

  if ($null -eq $Object) {
    @() | Export-Csv -NoTypeInformation -Encoding UTF8 -Path $Path -Force
    return
  }

  @($Object) | Export-Csv -NoTypeInformation -Encoding UTF8 -Path $Path -Force
}

function Invoke-WithRetry {
  param(
    [Parameter(Mandatory)][string]$Name,
    [Parameter(Mandatory)][scriptblock]$ScriptBlock,
    [int]$MaxAttempts = 3,
    [int]$InitialDelaySeconds = 3,
    [switch]$NonTerminating
  )

  $attempt = 0
  $delay = [Math]::Max(1, $InitialDelaySeconds)
  $lastError = $null

  while ($attempt -lt $MaxAttempts) {
    $attempt++
    try {
      Write-Log -Level Info -Step $Name -Message ("Starting attempt {0} of {1}" -f $attempt, $MaxAttempts)
      $result = & $ScriptBlock
      Write-Log -Level Info -Step $Name -Message ("Succeeded on attempt {0}" -f $attempt)
      return $result
    }
    catch {
      $lastError = $_
      Write-Log -Level Warn -Step $Name -Message ("Attempt {0} failed: {1}" -f $attempt, $_.Exception.Message)

      if ($attempt -lt $MaxAttempts) {
        Write-Log -Level Info -Step $Name -Message ("Retrying in {0} seconds" -f $delay)
        Start-Sleep -Seconds $delay
        $delay = [Math]::Min(($delay * 2), 30)
      }
    }
  }

  $detail = if ($lastError) { $lastError | Out-String } else { "" }
  Add-RunIssue -Type Error -Step $Name -Message ("Failed after {0} attempts" -f $MaxAttempts) -Detail $detail

  if (-not $NonTerminating) {
    throw $lastError
  }

  return $null
}

function Invoke-Step {
  param(
    [Parameter(Mandatory)][string]$Name,
    [Parameter(Mandatory)][scriptblock]$ScriptBlock,
    [switch]$ContinueOnError
  )

  $sw = [System.Diagnostics.Stopwatch]::StartNew()
  try {
    $result = Invoke-WithRetry -Name $Name -ScriptBlock $ScriptBlock -MaxAttempts $RetryCount -InitialDelaySeconds $RetryDelaySeconds -NonTerminating:$ContinueOnError
    $sw.Stop()

    $script:Summary.Add([pscustomobject]@{
      SnapshotId      = $script:SnapshotId
      RunDateUtc      = $script:RunDateUtc
      Step            = $Name
      Status          = if ($null -eq $result -and $ContinueOnError) { 'CompletedWithNoResult' } else { 'Success' }
      DurationSeconds = [math]::Round($sw.Elapsed.TotalSeconds, 2)
    })

    return $result
  }
  catch {
    $sw.Stop()
    $script:Summary.Add([pscustomobject]@{
      SnapshotId      = $script:SnapshotId
      RunDateUtc      = $script:RunDateUtc
      Step            = $Name
      Status          = 'Failed'
      DurationSeconds = [math]::Round($sw.Elapsed.TotalSeconds, 2)
    })
    throw
  }
}

# -------------------------------
# Bootstrap / module helpers
# -------------------------------
function Ensure-PackageManagement {
  try {
    if (-not (Get-PackageProvider -Name NuGet -ListAvailable -ErrorAction SilentlyContinue)) {
      Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 -Force -Scope CurrentUser | Out-Null
    }

    if ($TrustPSGallery) {
      $gallery = Get-PSRepository -Name PSGallery -ErrorAction SilentlyContinue
      if ($gallery -and $gallery.InstallationPolicy -ne 'Trusted') {
        Set-PSRepository -Name PSGallery -InstallationPolicy Trusted
      }
    }
  }
  catch {
    throw "Failed to initialise package management: $($_.Exception.Message)"
  }
}

function Ensure-Module {
  param(
    [Parameter(Mandatory)][string]$Name,
    [string]$MinimumVersion = '',
    [switch]$AllowClobber
  )

  $installed = Get-Module -ListAvailable -Name $Name | Sort-Object Version -Descending | Select-Object -First 1
  $needsInstall = $false

  if (-not $installed) {
    $needsInstall = $true
  }
  elseif ($MinimumVersion) {
    try {
      if ([version]$installed.Version -lt [version]$MinimumVersion) {
        $needsInstall = $true
      }
    }
    catch {
      $needsInstall = $true
    }
  }

  if ($needsInstall) {
    if (-not $AutoInstallMissingModules) {
      throw "Required module '$Name' is missing or below minimum version '$MinimumVersion'."
    }

    $installParams = @{
      Name        = $Name
      Scope       = $InstallScope
      Force       = $true
      ErrorAction = 'Stop'
    }
    if ($AllowClobber) { $installParams['AllowClobber'] = $true }
    if ($MinimumVersion) { $installParams['MinimumVersion'] = $MinimumVersion }

    Write-Log -Level Info -Step 'Bootstrap-Modules' -Message ("Installing module {0}" -f $Name)
    Install-Module @installParams | Out-Null
  }

  Import-Module $Name -ErrorAction Stop -Force
}

function Connect-GraphSafe {
  param([string[]]$Scopes)

  $uniqueScopes = @($Scopes | Where-Object { $_ } | Select-Object -Unique)
  if ($UseDeviceAuthentication) {
    Connect-MgGraph -Scopes $uniqueScopes -NoWelcome -UseDeviceAuthentication | Out-Null
  }
  else {
    Connect-MgGraph -Scopes $uniqueScopes -NoWelcome | Out-Null
  }
}

function Disconnect-Safely {
  param(
    [Parameter(Mandatory)][ValidateSet('Graph','Exchange','SPO','PnP')][string]$ConnectionType,
    [string]$Step = 'Disconnect'
  )

  try {
    switch ($ConnectionType) {
      'Graph'    { Disconnect-MgGraph -ErrorAction SilentlyContinue | Out-Null }
      'Exchange' { Disconnect-ExchangeOnline -Confirm:$false -ErrorAction SilentlyContinue }
      'PnP'      { Disconnect-PnPOnline -ErrorAction SilentlyContinue }
      'SPO'      {
        # No standard Disconnect-SPOService cmdlet exists.
        # Intentionally treated as a no-op for cleanup.
      }
    }

    Write-Log -Level Info -Step $Step -Message ("Disconnected / cleaned up {0}" -f $ConnectionType)
  }
  catch {
    Write-Log -Level Warn -Step $Step -Message ("Disconnect warning for {0}: {1}" -f $ConnectionType, $_.Exception.Message)
  }
}

# -------------------------------
# Data helpers
# -------------------------------
function Read-SkuMap {
  param([Parameter(Mandatory)][string]$Path)
  if (Test-Path -LiteralPath $Path) {
    return (Get-Content -Raw -Path $Path | ConvertFrom-Json -ErrorAction Stop)
  }

  Write-Log -Level Warn -Step 'Read-SkuMap' -Message ("SKU map file not found: {0}" -f $Path)
  Add-RunIssue -Type Warning -Step 'Read-SkuMap' -Message 'SKU map file not found' -Detail $Path
  return $null
}

function Resolve-SkuIdsFromPartNumbers {
  param(
    [Parameter(Mandatory)]$SubscribedSkus,
    [Parameter(Mandatory)][string[]]$PartNumbers
  )

  $ids = New-Object System.Collections.Generic.List[string]
  foreach ($pn in $PartNumbers) {
    $match = $SubscribedSkus | Where-Object { $_.SkuPartNumber -eq $pn } | Select-Object -First 1
    if ($match -and $match.SkuId) {
      $ids.Add([string]$match.SkuId)
    }
  }
  return @($ids)
}

function Test-UserHasAnySkuId {
  param($UserSkuIds, $WantedSkuIds)

  foreach ($id in @($WantedSkuIds)) {
    if (@($UserSkuIds) -contains $id) { return $true }
  }
  return $false
}

function Try-ParseJson {
  param($Text)
  try { return ($Text | ConvertFrom-Json -ErrorAction Stop) } catch { return $null }
}

# -------------------------------
# HTML report helpers
# -------------------------------
function Get-RagClass {
  param(
    [Parameter(Mandatory = $false)]$Score,
    [string]$Priority = ''
  )

  try { $scoreValue = [int]$Score } catch { $scoreValue = -1 }

  if ($Priority -eq 'P0' -and ($scoreValue -lt 50 -or $scoreValue -eq 0)) { return 'rag-red' }
  if ($Priority -eq 'P1' -and ($scoreValue -lt 50 -or $scoreValue -eq 0)) { return 'rag-amber' }
  if ($scoreValue -ge 80) { return 'rag-green' }
  if ($scoreValue -ge 50) { return 'rag-amber' }
  if ($scoreValue -ge 0)  { return 'rag-red' }
  return 'rag-grey'
}

function New-HtmlReport {
  param(
    [Parameter(Mandatory)][string]$OutputPath,
    [Parameter(Mandatory)][string]$SnapshotId
  )

  function Load-CsvSafe {
    param([Parameter(Mandatory)][string]$Path)
    if (Test-Path -LiteralPath $Path) { return @(Import-Csv -Path $Path) }
    return @()
  }

  function Convert-ToHtmlSafe {
    param([string]$Value)
    if ($null -eq $Value) { return '' }
    return [System.Net.WebUtility]::HtmlEncode([string]$Value)
  }

  $tenant   = Load-CsvSafe -Path (Join-Path $OutputPath 'TenantSnapshot.csv')
  $users    = Load-CsvSafe -Path (Join-Path $OutputPath 'Users_Licensing.csv')
  $ca       = Load-CsvSafe -Path (Join-Path $OutputPath 'Entra_ConditionalAccess.csv')
  $roles    = Load-CsvSafe -Path (Join-Path $OutputPath 'Entra_Roles.csv')
  $groups   = Load-CsvSafe -Path (Join-Path $OutputPath 'Teams_Groups.csv')
  $spo      = Load-CsvSafe -Path (Join-Path $OutputPath 'SharePoint_TenantSharing.csv')
  $scores   = Load-CsvSafe -Path (Join-Path $OutputPath 'Summary_Scores.csv')
  $warnings = Load-CsvSafe -Path (Join-Path $OutputPath 'Run_Warnings.csv')
  $errors   = Load-CsvSafe -Path (Join-Path $OutputPath 'Run_Errors.csv')

  $tenantRow = $tenant | Select-Object -First 1
  $spoRow = $spo | Select-Object -First 1

  $totalUsers = @($users).Count
  $enabledUsers = @($users | Where-Object { $_.AccountEnabled -eq 'True' }).Count
  $copilotAssigned = @($users | Where-Object { $_.HasCopilotAddOn -eq 'True' }).Count
  $eligibleBaseUsers = @($users | Where-Object { $_.HasEligibleBaseSku -eq 'True' }).Count
  $copilotCoverage = if ($totalUsers -gt 0) { [math]::Round(($copilotAssigned / $totalUsers) * 100, 1) } else { 0 }
  $caPolicies = @($ca).Count
  $groupsCount = @($groups).Count
  $warningCount = @($warnings).Count
  $errorCount = @($errors).Count
  $scoreRows = @($scores)

  $overallStatusClass = 'rag-grey'
  if ($errorCount -gt 0) {
    $overallStatusClass = 'rag-red'
  }
  elseif ($warningCount -gt 0) {
    $overallStatusClass = 'rag-amber'
  }
  elseif (@($scores).Count -gt 0) {
    if ((@($scores | Where-Object { (Get-RagClass -Score $_.Score -Priority $_.Priority) -eq 'rag-red' }).Count) -gt 0) {
      $overallStatusClass = 'rag-red'
    }
    elseif ((@($scores | Where-Object { (Get-RagClass -Score $_.Score -Priority $_.Priority) -eq 'rag-amber' }).Count) -gt 0) {
      $overallStatusClass = 'rag-amber'
    }
    else {
      $overallStatusClass = 'rag-green'
    }
  }

  $risks = New-Object System.Collections.Generic.List[object]

  if ($totalUsers -gt 0 -and $copilotAssigned -eq 0) {
    $risks.Add([pscustomobject]@{
      RAG           = 'Red'
      Category      = 'Licensing'
      Risk          = 'No users in the export are marked with Copilot add-on licences.'
      WhyItMatters  = 'Copilot value cannot be realised until licensing is assigned to target users.'
      Evidence      = ('Users_Licensing.csv shows 0 users with HasCopilotAddOn=True out of {0} users.' -f $totalUsers)
    })
  }
  elseif ($copilotCoverage -lt 20 -and $totalUsers -gt 0) {
    $risks.Add([pscustomobject]@{
      RAG           = 'Amber'
      Category      = 'Licensing'
      Risk          = 'Copilot licence assignment appears limited across the exported user set.'
      WhyItMatters  = 'Pilot scale may be too small to validate readiness across representative personas and workloads.'
      Evidence      = ('Users_Licensing.csv shows {0}% coverage ({1}/{2} users).' -f $copilotCoverage, $copilotAssigned, $totalUsers)
    })
