#requires -Version 5.1
#requires -RunAsAdministrator
# ==============================
# AI Readiness & Adoption (Sub-300) - Automation Script (Business Premium + Defender + Purview + Intune)
#
# What it does (high level):
# - Installs required modules
# - Prompts for required variables
# - Connects to Microsoft Graph
# - Creates standard groups (if missing)
# - Creates baseline Conditional Access policies in Report-only by default
# - Optional: Intune baseline automation (pilot-scoped)
# - Optional: Copilot group-based licensing
# - Optional: Defender for Office 365 configuration
# - Optional: Purview labels + DLP (audit-first)
# - Evidence exports for handover
#
# Safety notes:
# - Keep break-glass accounts excluded from CA policies.
# - CA policies are created in REPORT-ONLY by default.
# - Intune baseline is PILOT-SCOPED and uses conservative defaults; validate conflicts before broad rollout.
# - Defender/Purview configuration changes are OFF by default and require explicit confirmation.
# ==============================

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

# Define constants
$LOG_DIR = $null
$MAX_RETRIES = 3
$RETRY_DELAY_MS = 1000

# ------------------------------
# Helper: Logging function
# ------------------------------
function Write-Log {
    param(
        [Parameter(Mandatory)][string]$Message,
        [ValidateSet('Info', 'Warning', 'Error')][string]$Level = 'Info',
        [switch]$NoConsole
    )
    $timestamp = (Get-Date).ToString('yyyy-MM-dd HH:mm:ss')
    $logEntry = "[$timestamp] [$Level] $Message"
    
    if (-not $NoConsole) {
        switch ($Level) {
            'Info' { Write-Host $logEntry }
            'Warning' { Write-Warning $logEntry }
            'Error' { Write-Host $logEntry -ForegroundColor Red }
        }
    }
    
    if ($LOG_DIR) {
        $logFile = Join-Path $LOG_DIR 'execution.log'
        Add-Content -Path $logFile -Value $logEntry
    }
}

# ------------------------------
# Helper: Retry wrapper for API calls
# ------------------------------
function Invoke-RetryableOperation {
    param(
        [Parameter(Mandatory)][scriptblock]$ScriptBlock,
        [string]$OperationName = 'Operation'
    )
    
    for ($attempt = 1; $attempt -le $MAX_RETRIES; $attempt++) {
        try {
            Write-Log "Attempting: $OperationName (attempt $attempt/$MAX_RETRIES)"
            return & $ScriptBlock
        } catch {
            Write-Log "Failed: $($_.Exception.Message)" -Level Warning
            if ($attempt -lt $MAX_RETRIES) {
                Start-Sleep -Milliseconds $RETRY_DELAY_MS
            } else {
                throw
            }
        }
    }
}

# ------------------------------
# Helper: Simple Yes/No prompt
# ------------------------------
function Read-YesNo {
    param(
        [Parameter(Mandatory)][string]$Prompt,
        [bool]$DefaultYes = $true
    )
    $defaultText = if ($DefaultYes) { '[Y]/N' } else { 'Y/[N]' }
    while ($true) {
        $r = Read-Host "$Prompt $defaultText"
        if ([string]::IsNullOrWhiteSpace($r)) { return $DefaultYes }
        switch ($r.Trim().ToLower()) {
            'y' { return $true }
            'yes' { return $true }
            'n' { return $false }
            'no' { return $false }
            default { Write-Host 'Please enter Y or N.' }
        }
    }
}

# ------------------------------
# Helper: Ensure NuGet provider / TLS for PSGallery
# ------------------------------
function Initialize-PSGallery {
    try { [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 } catch { }
    if (-not (Get-PackageProvider -Name NuGet -ErrorAction SilentlyContinue)) {
        Write-Log 'Installing NuGet package provider...'
        Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 -Force | Out-Null
    }
    $psg = Get-PSRepository -Name 'PSGallery' -ErrorAction SilentlyContinue
    if ($psg -and $psg.InstallationPolicy -ne 'Trusted') {
        if (Read-YesNo -Prompt 'Set PSGallery to Trusted (recommended for automation)?' -DefaultYes $true) {
            Set-PSRepository -Name 'PSGallery' -InstallationPolicy Trusted
        }
    }
}

# ------------------------------
# Helper: Ensure modules installed/imported
# ------------------------------
function Ensure-Module {
    param(
        [Parameter(Mandatory)][string]$Name,
        [string]$MinimumVersion = ''
    )
    $installed = Get-Module -ListAvailable -Name $Name | Sort-Object Version -Descending | Select-Object -First 1
    if (-not $installed -or ($MinimumVersion -and ([version]$installed.Version -lt [version]$MinimumVersion))) {
        Write-Log "Installing module: $Name"
        if ($MinimumVersion) {
            Install-Module -Name $Name -MinimumVersion $MinimumVersion -Scope CurrentUser -Force -AllowClobber
        } else {
            Install-Module -Name $Name -Scope CurrentUser -Force -AllowClobber
        }
    }
    Import-Module $Name -ErrorAction Stop
}

# ------------------------------
# Helper: JSON export with logging
# ------------------------------
function Export-Json {
    param(
        [Parameter(Mandatory)]$Object,
        [Parameter(Mandatory)][string]$Path,
        [int]$Depth = 8
    )
    try {
        $Object | ConvertTo-Json -Depth $Depth | Out-File -FilePath $Path -Encoding utf8
        Write-Log "Exported to: $Path"
    } catch {
        Write-Log "Failed to export JSON to $Path : $($_.Exception.Message)" -Level Warning
    }
}

# ------------------------------
# Helper: Graph request wrapper with retry
# ------------------------------
function Invoke-Graph {
    param(
        [Parameter(Mandatory)][ValidateSet('GET','POST','PATCH')][string]$Method,
        [Parameter(Mandatory)][string]$Uri,
        [object]$Body = $null,
        [string]$Description = 'Graph request'
    )
    
    Invoke-RetryableOperation -ScriptBlock {
        if ($Body) {
            $json = $Body | ConvertTo-Json -Depth 25
            return Invoke-MgGraphRequest -Method $Method -Uri $Uri -Body $json -ContentType 'application/json'
        } else {
            return Invoke-MgGraphRequest -Method $Method -Uri $Uri
        }
    } -OperationName $Description
}

# ------------------------------
# Helper: Escape filter strings for Graph
# ------------------------------
function Escape-FilterString {
    param([Parameter(Mandatory)][string]$String)
    return $String.Replace("'","''")
}

