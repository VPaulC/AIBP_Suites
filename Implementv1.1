    displayName = $CA_AdminPortals_Name
    state = 'enabledForReportingButNotEnforced'
    conditions = @{
        clientAppTypes = @('browser')
        applications = @{
            includeApplications = @(
                'c44b4083-3bb0-49c1-b47d-974e53cbdf3c',  # MS Azure Management
                '00000007-0000-0ff1-ce00-000000000000'    # Office 365 Management API
