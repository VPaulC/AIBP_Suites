    Write-Log '=== Attempting Copilot group-based licensing ==='
    try {
        Write-Log 'Searching subscribed SKUs for Copilot...'
        $skus = Invoke-RetryableOperation -ScriptBlock { Get-MgSubscribedSku -All } -OperationName 'Get subscribed SKUs'
        $copilot = $skus | Where-Object { $_.SkuPartNumber -eq $CopilotSkuPartNumberHint } | Select-Object -First 1
        
        if (-not $copilot) {
            Write-Log "Could not find SKU '$CopilotSkuPartNumberHint'. Available SKUs:" -Level Warning
            $skus | Select-Object SkuPartNumber, SkuId | Sort-Object SkuPartNumber | Format-Table -AutoSize | Out-String | Write-Host
            Write-Log 'Skipping Copilot licensing step.'
        } else {
            Write-Log "Assigning SKU to pilot group: $($copilot.SkuPartNumber)"
            $licenseParams = @{ 
                AddLicenses = @(@{ SkuId = $copilot.SkuId })
                RemoveLicenses = @() 
            }
            Set-MgGroupLicense -GroupId $gPilot.Id -BodyParameter $licenseParams | Out-Null
            Write-Log 'Copilot license assigned to pilot group successfully'
        }
    } catch {
        Write-Log "Group-based licensing failed: $($_.Exception.Message)" -Level Warning
    }
} else {
    Write-Log 'Skipping Copilot licensing step (operator selected No).'
}

# ------------------------------
# Purview helpers (Compliance PowerShell)
# ------------------------------
function Connect-Compliance {
    Write-Log 'Connecting to Microsoft Purview (Security & Compliance PowerShell)...'
    Connect-IPPSSession -ErrorAction Stop | Out-Null
}

function Get-OrCreateSensitivityLabel {
    param([Parameter(Mandatory)][hashtable]$Label)
    $name = $Label.Name
    $existing = Get-Label -Identity $name -ErrorAction SilentlyContinue
    if (-not $existing) {
        Write-Log "Creating label: $name"
        New-Label -Name $name -DisplayName $Label.DisplayName -Tooltip $Label.Tooltip -ErrorAction Stop | Out-Null
    } else {
        Write-Log "Label exists: $name (updating display/tooltip if needed)"
        Set-Label -Identity $name -DisplayName $Label.DisplayName -Tooltip $Label.Tooltip -ErrorAction SilentlyContinue | Out-Null
    }
    return Get-Label -Identity $name -ErrorAction Stop
}

function Get-OrCreateLabelPolicy {
    param(
        [Parameter(Mandatory)][string]$PolicyName,
        [Parameter(Mandatory)][string[]]$LabelNames,
        [Parameter(Mandatory)][string]$ScopeValue
    )
    $existing = Get-LabelPolicy -Identity $PolicyName -ErrorAction SilentlyContinue
    if (-not $existing) {
        Write-Log "Creating label policy: $PolicyName"
        try {
            New-LabelPolicy -Name $PolicyName -Labels $LabelNames -ExchangeLocation $ScopeValue -SharePointLocation $ScopeValue -OneDriveLocation $ScopeValue -ErrorAction Stop | Out-Null
        } catch {
            Write-Log "Could not scope label policy to '$ScopeValue'. Creating policy to 'All' (adjust scope in portal if required)." -Level Warning
            New-LabelPolicy -Name $PolicyName -Labels $LabelNames -ExchangeLocation All -SharePointLocation All -OneDriveLocation All -ErrorAction Stop | Out-Null
        }
    } else {
        Write-Log "Label policy exists: $PolicyName (ensuring labels included)"
        try { Set-LabelPolicy -Identity $PolicyName -AddLabels $LabelNames -ErrorAction Stop | Out-Null } catch { }
    }
    return Get-LabelPolicy -Identity $PolicyName -ErrorAction SilentlyContinue
}

function Get-OrCreateDlpPolicyAndRule {
    param(
        [Parameter(Mandatory)][string]$PolicyName,
        [Parameter(Mandatory)][string]$RuleName,
        [Parameter(Mandatory)][string[]]$SensitiveInfoTypes,
        [ValidateSet('Audit','Enforce')][string]$Mode = 'Audit'
    )
    $policy = Get-DlpCompliancePolicy -Identity $PolicyName -ErrorAction SilentlyContinue
    if (-not $policy) {
        Write-Log "Creating DLP policy: $PolicyName"
        New-DlpCompliancePolicy -Name $PolicyName -Mode Test -Comment 'Created by AI Readiness automation (audit-first)' -ErrorAction Stop | Out-Null
    } else {
        Write-Log "DLP policy exists: $PolicyName"
    }
    
    $rule = Get-DlpComplianceRule -Identity $RuleName -ErrorAction SilentlyContinue
    $sitExpr = @{ Name = $SensitiveInfoTypes; minCount = 1 }
    
    if (-not $rule) {
        Write-Log "Creating DLP rule: $RuleName"
        New-DlpComplianceRule -Name $RuleName -Policy $PolicyName -ContentContainsSensitiveInformation $sitExpr -NotifyUser $true -UserNotifications 'NotifyUser' -GenerateAlert $true -IncidentReportContent 'All' -ErrorAction Stop | Out-Null
    } else {
        Write-Log "DLP rule exists: $RuleName (no destructive updates applied)"
    }
    
    if ($Mode -eq 'Audit') {
        try { Set-DlpCompliancePolicy -Identity $PolicyName -Mode Test -ErrorAction Stop | Out-Null } catch { }
    } else {
        try { Set-DlpCompliancePolicy -Identity $PolicyName -Mode Enable -ErrorAction Stop | Out-Null } catch { }
    }
}

# ------------------------------
# Purview configuration (Sensitivity labels + publishing + DLP audit-first)
# ------------------------------
if ($DoPurviewConfig) {
    Write-Log '=== Configuring Microsoft Purview (labels + DLP) ==='
    $purDir = Join-Path $OutDir 'Purview'
    New-Item -ItemType Directory -Path $purDir -Force | Out-Null
    
    try {
        Connect-Compliance
        $labelNames = New-Object System.Collections.Generic.List[string]
        
        if ($PurviewCreateLabels) {
            foreach ($l in $PurviewLabelSet) {
                $created = Get-OrCreateSensitivityLabel -Label $l
                $labelNames.Add($created.Name)
            }
        } else {
            foreach ($l in $PurviewLabelSet) { $labelNames.Add($l.Name) }
        }
        
        if ($PurviewPublishLabels) {
            $polName = "LP01 - Labels - $GroupPrefix (Pilot)"
            Get-OrCreateLabelPolicy -PolicyName $polName -LabelNames $labelNames.ToArray() -ScopeValue $PurviewPilotGroupName | Out-Null
        }
        
        if ($PurviewCreateDlp) {
            $dlpName = "DLP01 - Sensitive info - $GroupPrefix"
            $dlpRule = "DLP01R - Sensitive info - $GroupPrefix"
            $sits = $PurviewSITsRaw.Split(',') | ForEach-Object { $_.Trim() } | Where-Object { $_ }
            if ($sits.Count -gt 0) {
                Get-OrCreateDlpPolicyAndRule -PolicyName $dlpName -RuleName $dlpRule -SensitiveInfoTypes $sits -Mode $PurviewDlpMode
            } else {
                Write-Log 'No sensitive info types specified for DLP rule' -Level Warning
            }
        }
        
        # Export Purview configuration
        try { Get-Label | Select-Object Name, DisplayName, Tooltip, WhenCreated, WhenChanged | ConvertTo-Json -Depth 6 | Out-File (Join-Path $purDir 'labels.json') -Encoding utf8 } catch { }
        try { Get-LabelPolicy | Select-Object Name, Labels, Enabled, Mode, ExchangeLocation, SharePointLocation, OneDriveLocation | ConvertTo-Json -Depth 8 | Out-File (Join-Path $purDir 'label-policies.json') -Encoding utf8 } catch { }
        try { Get-DlpCompliancePolicy | Select-Object Name, Mode, State, Comment | ConvertTo-Json -Depth 6 | Out-File (Join-Path $purDir 'dlp-policies.json') -Encoding utf8 } catch { }
        try { Get-DlpComplianceRule | Select-Object Name, Policy, Disabled, ContentContainsSensitiveInformation | ConvertTo-Json -Depth 10 | Out-File (Join-Path $purDir 'dlp-rules.json') -Encoding utf8 } catch { }
        
        Write-Log 'Purview configuration completed successfully'
        try { Disconnect-IPPSSession -ErrorAction SilentlyContinue | Out-Null } catch { }
    } catch {
        Write-Log "Purview configuration failed: $($_.Exception.Message)" -Level Warning
        try { Disconnect-IPPSSession -ErrorAction SilentlyContinue | Out-Null } catch { }
    }
}

# ------------------------------
# Defender for Office 365 (MDO) policy configuration (Exchange Online)
# ------------------------------
if ($DoMdoConfig) {
    Write-Log '=== Configuring Microsoft Defender for Office 365 policies ==='
    $mdoDir = Join-Path $OutDir 'MDO'
    New-Item -ItemType Directory -Path $mdoDir -Force | Out-Null
    
    try {
        Write-Log 'Connecting to Exchange Online...'
        Connect-ExchangeOnline -ShowBanner:$false | Out-Null
        
        $standardRecipients = @()
        $strictRecipients = @()
        
        if ($MdoUsePresets) {
            Write-Log "Resolving Standard group for presets: $MdoStandardGroupName"
            $stdGroup = Get-DistributionGroup -Identity $MdoStandardGroupName -ErrorAction SilentlyContinue
            if (-not $stdGroup) { $stdGroup = Get-UnifiedGroup -Identity $MdoStandardGroupName -ErrorAction SilentlyContinue }
            if (-not $stdGroup) { $stdGroup = Get-Recipient -Identity $MdoStandardGroupName -ErrorAction SilentlyContinue }
            
            if ($stdGroup) {
                $standardRecipients = @($stdGroup.PrimarySmtpAddress.ToString())
                Write-Log "Standard group resolved: $($standardRecipients[0])"
            } else {
                Write-Log "Could not resolve Standard group: $MdoStandardGroupName" -Level Warning
            }
            
            if (-not [string]::IsNullOrWhiteSpace($MdoStrictGroupName)) {
                Write-Log "Resolving Strict group for presets: $MdoStrictGroupName"
                $stGroup = Get-DistributionGroup -Identity $MdoStrictGroupName -ErrorAction SilentlyContinue
                if (-not $stGroup) { $stGroup = Get-UnifiedGroup -Identity $MdoStrictGroupName -ErrorAction SilentlyContinue }
                if (-not $stGroup) { $stGroup = Get-Recipient -Identity $MdoStrictGroupName -ErrorAction SilentlyContinue }
                
                if ($stGroup) {
                    $strictRecipients = @($stGroup.PrimarySmtpAddress.ToString())
                    Write-Log "Strict group resolved: $($strictRecipients[0])"
                } else {
                    Write-Log "Could not resolve Strict group: $MdoStrictGroupName" -Level Warning
                }
            }
        }
        
        if ($standardRecipients.Count -gt 0) {
            Write-Log 'Enabling/updating Preset security policies...'
            try {
                Set-AtpPolicyForO365 -Identity 'Standard Preset Security Policy' -Enable $true -TargetedUsersToProtect $standardRecipients -ErrorAction Stop
                Write-Log 'Standard Preset Security Policy enabled'
            } catch {
                $pol = Get-AtpPolicyForO365 | Where-Object { $_.Name -match 'Standard' } | Select-Object -First 1
                if ($pol) { 
                    Set-AtpPolicyForO365 -Identity $pol.Identity -Enable $true -TargetedUsersToProtect $standardRecipients
                    Write-Log 'Standard Preset Security Policy updated'
                } else { 
                    throw 
                }
            }
        }
        
        if ($strictRecipients.Count -gt 0) {
            try {
                Set-AtpPolicyForO365 -Identity 'Strict Preset Security Policy' -Enable $true -TargetedUsersToProtect $strictRecipients -ErrorAction Stop
                Write-Log 'Strict Preset Security Policy enabled'
            } catch {
                $pol2 = Get-AtpPolicyForO365 | Where-Object { $_.Name -match 'Strict' } | Select-Object -First 1
                if ($pol2) { 
                    Set-AtpPolicyForO365 -Identity $pol2.Identity -Enable $true -TargetedUsersToProtect $strictRecipients
                    Write-Log 'Strict Preset Security Policy updated'
                } else { 
                    throw 
                }
            }
        } else {
            Write-Log 'Strict preset not configured (no Strict group provided).' -Level Warning
        }
        
        # ZAP Configuration
        if ($MdoEnableZAP) {
            try { 
                Set-OrganizationConfig -ZapEnabled $true -ErrorAction Stop | Out-Null 
                Write-Log 'Zero Hour Auto Purge (ZAP) enabled'
            } catch { 
                Write-Log "Could not set ZAP: $($_.Exception.Message)" -Level Warning 
            }
        }
        
        # Safe Links
        if ($MdoEnableSafeLinks -and $standardRecipients.Count -gt 0) {
            try {
                $slName = "SL01 - Safe Links - $GroupPrefix"
                $existingSl = Get-SafeLinksPolicy -ErrorAction SilentlyContinue | Where-Object { $_.Name -eq $slName } | Select-Object -First 1
                
                if (-not $existingSl) {
                    New-SafeLinksPolicy -Name $slName -IsEnabled $true -ScanUrls $true -EnableSafeLinksForTeams $true -EnableSafeLinksForOffice $true -DoNotTrackUserClicks $MdoSafeLinksDoNotTrack -AllowClickThrough $false | Out-Null
                    Write-Log "Created Safe Links policy: $slName"
                } else {
                    Set-SafeLinksPolicy -Identity $slName -IsEnabled $true -ScanUrls $true -EnableSafeLinksForTeams $true -EnableSafeLinksForOffice $true -DoNotTrackUserClicks $MdoSafeLinksDoNotTrack -AllowClickThrough $false | Out-Null
                    Write-Log "Updated Safe Links policy: $slName"
                }
                
                $slRuleName = "SLR01 - Safe Links - $GroupPrefix"
                $existingRule = Get-SafeLinksRule -ErrorAction SilentlyContinue | Where-Object { $_.Name -eq $slRuleName } | Select-Object -First 1
                
                if (-not $existingRule) { 
                    New-SafeLinksRule -Name $slRuleName -SafeLinksPolicy $slName -SentToMemberOf $standardRecipients -Priority 0 | Out-Null
                    Write-Log "Created Safe Links rule: $slRuleName"
                } else { 
                    Set-SafeLinksRule -Identity $slRuleName -SafeLinksPolicy $slName -SentToMemberOf $standardRecipients | Out-Null
                    Write-Log "Updated Safe Links rule: $slRuleName"
                }
            } catch { 
                Write-Log "Safe Links configuration failed: $($_.Exception.Message)" -Level Warning 
            }
        }
        
        # Safe Attachments
        if ($MdoEnableSafeAttachments -and $standardRecipients.Count -gt 0) {
            try {
                $saName = "SA01 - Safe Attachments - $GroupPrefix"
                $existingSa = Get-SafeAttachmentPolicy -ErrorAction SilentlyContinue | Where-Object { $_.Name -eq $saName } | Select-Object -First 1
                
                if (-not $existingSa) { 
                    New-SafeAttachmentPolicy -Name $saName -Enable $true -Action $MdoSafeAttachmentsAction | Out-Null
                    Write-Log "Created Safe Attachments policy: $saName"
                } else { 
                    Set-SafeAttachmentPolicy -Identity $saName -Enable $true -Action $MdoSafeAttachmentsAction | Out-Null
                    Write-Log "Updated Safe Attachments policy: $saName"
                }
                
                $saRuleName = "SAR01 - Safe Attachments - $GroupPrefix"
                $existingSaRule = Get-SafeAttachmentRule -ErrorAction SilentlyContinue | Where-Object { $_.Name -eq $saRuleName } | Select-Object -First 1
                
                if (-not $existingSaRule) { 
                    New-SafeAttachmentRule -Name $saRuleName -SafeAttachmentPolicy $saName -SentToMemberOf $standardRecipients -Priority 0 | Out-Null
                    Write-Log "Created Safe Attachments rule: $saRuleName"
                } else { 
                    Set-SafeAttachmentRule -Identity $saRuleName -SafeAttachmentPolicy $saName -SentToMemberOf $standardRecipients | Out-Null
                    Write-Log "Updated Safe Attachments rule: $saRuleName"
                }
            } catch { 
                Write-Log "Safe Attachments configuration failed: $($_.Exception.Message)" -Level Warning 
            }
        }
        
        # Export MDO configuration
        try { Get-AtpPolicyForO365 | Select-Object Name, Enabled, TargetedUsersToProtect | ConvertTo-Json -Depth 6 | Out-File (Join-Path $mdoDir 'preset-policies.json') -Encoding utf8 } catch { }
        try { Get-SafeLinksPolicy | Select-Object Name, IsEnabled, DoNotTrackUserClicks, AllowClickThrough, EnableSafeLinksForTeams, EnableSafeLinksForOffice | ConvertTo-Json -Depth 6 | Out-File (Join-Path $mdoDir 'safelinks-policies.json') -Encoding utf8 } catch { }
        try { Get-SafeLinksRule | Select-Object Name, SafeLinksPolicy, State, Priority, SentToMemberOf | ConvertTo-Json -Depth 6 | Out-File (Join-Path $mdoDir 'safelinks-rules.json') -Encoding utf8 } catch { }
        try { Get-SafeAttachmentPolicy | Select-Object Name, Enable, Action | ConvertTo-Json -Depth 6 | Out-File (Join-Path $mdoDir 'safeattachments-policies.json') -Encoding utf8 } catch { }
        try { Get-SafeAttachmentRule | Select-Object Name, SafeAttachmentPolicy, State, Priority, SentToMemberOf | ConvertTo-Json -Depth 6 | Out-File (Join-Path $mdoDir 'safeattachments-rules.json') -Encoding utf8 } catch { }
        
        Write-Log 'MDO configuration completed successfully'
        Disconnect-ExchangeOnline -Confirm:$false | Out-Null
    } catch {
        Write-Log "MDO configuration failed: $($_.Exception.Message)" -Level Warning
        try { Disconnect-ExchangeOnline -Confirm:$false | Out-Null } catch { }
    }
}

# ------------------------------
# Defender evidence collection (read-only)
# ------------------------------
if ($DoDefenderEvidence) {
    Write-Log '=== Collecting Defender evidence ==='
    
    if ($DoOrca) {
        try {
            Write-Log 'Connecting to Exchange Online for ORCA...'
            Connect-ExchangeOnline -ShowBanner:$false | Out-Null
            
            $orcaOut = Join-Path $OutDir 'ORCA'
            New-Item -ItemType Directory -Path $orcaOut -Force | Out-Null
            
            Write-Log 'Running ORCA report (this may take a few minutes)...'
            Invoke-ORCA -OutputPath $orcaOut | Out-Null
            Write-Log 'ORCA report completed'
            
            Disconnect-ExchangeOnline -Confirm:$false | Out-Null
        } catch {
            Write-Log "ORCA step failed: $($_.Exception.Message)" -Level Warning
            try { Disconnect-ExchangeOnline -Confirm:$false | Out-Null } catch { }
        }
    }
    
    if ($DoSecureScore) {
        try {
            Write-Log 'Exporting Secure Score...'
            $secDir = Join-Path $OutDir 'Security'
            New-Item -ItemType Directory -Path $secDir -Force | Out-Null
            
            $scores = Invoke-Graph -Method GET -Uri 'https://graph.microsoft.com/v1.0/security/secureScores?$top=20' -Description 'Export Secure Scores'
            Export-Json -Object $scores -Path (Join-Path $secDir 'secureScores.json') -Depth 10
            
            $controls = Invoke-Graph -Method GET -Uri 'https://graph.microsoft.com/v1.0/security/secureScoreControlProfiles?$top=200' -Description 'Export Secure Score Control Profiles'
            Export-Json -Object $controls -Path (Join-Path $secDir 'secureScoreControlProfiles.json') -Depth 10
        } catch {
            Write-Log "Secure Score export failed: $($_.Exception.Message)" -Level Warning
        }
    }
    
    if ($DoMdeInventory) {
        try {
            Write-Log 'Exporting MDE machine inventory (read-only)...'
            $mdeDir = Join-Path $OutDir 'MDE'
            New-Item -ItemType Directory -Path $mdeDir -Force | Out-Null
            
            $uri = 'https://api.securitycenter.microsoft.com/api/machines'
            $machines = Invoke-Graph -Method GET -Uri $uri -Description 'Export MDE machines'
            Export-Json -Object $machines -Path (Join-Path $mdeDir 'machines.json') -Depth 10
            
            if ($machines.value) {
                $machines.value | Select-Object computerDnsName, osPlatform, healthStatus, onboardingStatus, lastSeen | Export-Csv (Join-Path $mdeDir 'machines-summary.csv') -NoTypeInformation
                Write-Log "Exported $($machines.value.Count) MDE machines"
            }
        } catch {
            Write-Log "MDE inventory export failed: $($_.Exception.Message)" -Level Warning
        }
    }
} else {
    Write-Log 'Skipping Defender evidence collection (operator selected No).'
}

# ------------------------------
# Final inventory export
# ------------------------------
Write-Log '=== Generating final inventory export ==='

$export = [ordered]@{
    RunTimestampUtc = (Get-Date).ToUniversalTime().ToString('o')
    ExecutedBy = $ctx.Account
    TenantId = $ctx.TenantId
    TenantDomain = $TenantDomainHint
    Groups = @{
        ITAdmins = @{
            DisplayName = $gIT.DisplayName
            Id = $gIT.Id
            MemberCount = (Get-MgGroupMember -GroupId $gIT.Id -All | Measure-Object).Count
        }
        CopilotPilot = @{
            DisplayName = $gPilot.DisplayName
            Id = $gPilot.Id
            MemberCount = (Get-MgGroupMember -GroupId $gPilot.Id -All | Measure-Object).Count
        }
        Exceptions = @{
            DisplayName = $gEx.DisplayName
            Id = $gEx.Id
            MemberCount = (Get-MgGroupMember -GroupId $gEx.Id -All | Measure-Object).Count
        }
    }
    BreakGlassAccounts = $BreakGlassUpns
    ConditionalAccessPolicies = (Get-MgIdentityConditionalAccessPolicy -All | Select-Object DisplayName, State, Id).Count
    Features = @{
        IntuneBaseline = $DoIntuneBaseline
        CopilotLicensing = $DoCopilotLicensing
        MdoConfig = $DoMdoConfig
        PurviewConfig = $DoPurviewConfig
        DefenderEvidence = $DoDefenderEvidence
    }
    OutputDirectory = $OutDir
}

Export-Json -Object $export -Path (Join-Path $OutDir 'automation-inventory.json') -Depth 10

Write-Log '================================'
Write-Log 'AI Readiness automation completed successfully!' -Level Info
Write-Log "Output directory: $OutDir"
Write-Log "Log file: $(Join-Path $LOG_DIR 'execution.log')"
Write-Log '================================'
