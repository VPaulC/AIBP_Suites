# ------------------------------
# Helpers: Groups and CA policies
# ------------------------------
function Get-OrCreateGroup {
    param(
        [Parameter(Mandatory)][string]$DisplayName,
        [string]$Description = 'Created by AI Readiness automation script'
    )
    $escaped = Escape-FilterString $DisplayName
    try {
        $existing = Get-MgGroup -Filter "displayName eq '$escaped'" -ConsistencyLevel eventual -All -ErrorAction SilentlyContinue
        if ($existing) {
            Write-Log "Group exists: $DisplayName"
            return $existing | Select-Object -First 1
        }
    } catch {
        Write-Log "Error checking for existing group $DisplayName : $($_.Exception.Message)" -Level Warning
    }
    
    $mailNick = ($DisplayName -replace '[^a-zA-Z0-9]','').ToLower()
    if ($mailNick.Length -gt 40) { $mailNick = $mailNick.Substring(0,40) }
    if ([string]::IsNullOrWhiteSpace($mailNick)) { $mailNick = "group_$([Guid]::NewGuid().ToString().Substring(0,8))" }
    
    Write-Log "Creating group: $DisplayName"
    try {
        $params = @{ 
            DisplayName = $DisplayName
            MailEnabled = $false
            MailNickname = $mailNick
            SecurityEnabled = $true
            Description = $Description 
        }
        return New-MgGroup -BodyParameter $params
    } catch {
        Write-Log "Failed to create group $DisplayName : $($_.Exception.Message)" -Level Error
        throw
    }
}

function Get-OrCreateCAPolicy {
    param([Parameter(Mandatory)][hashtable]$Body)
    $name = $Body.displayName
    try {
        $existing = Get-MgIdentityConditionalAccessPolicy -All | Where-Object { $_.DisplayName -eq $name }
        if ($existing) { 
            Write-Log "CA policy exists: $name"
            return $existing | Select-Object -First 1 
        }
    } catch {
        Write-Log "Error checking for existing CA policy $name : $($_.Exception.Message)" -Level Warning
    }
    
    Write-Log "Creating CA policy: $name"
    try {
        return New-MgIdentityConditionalAccessPolicy -BodyParameter $Body
    } catch {
        Write-Log "Failed to create CA policy $name : $($_.Exception.Message)" -Level Error
        throw
    }
}

# ------------------------------
# Create/reuse standard groups
# ------------------------------
