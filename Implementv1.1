                assignments = @(
                    @{
                        target = @{
                            '@odata.type' = '#microsoft.graph.groupAssignmentTarget'
                            groupId = $gPilotDevices.Id
                        }
                    }
                )
            }
            
            $assignUri = "https://graph.microsoft.com/v1.0/deviceManagement/deviceCompliancePolicies/$($mobilePolicy.Id)/assignments"
