    displayName = $CA_BlockLegacy_Name
    state = 'enabledForReportingButNotEnforced'
    conditions = @{
        applications = @{
            includeApplications = @('All')
        }
        clientAppTypes = @('other')
        users = @{
            includeUsers = @('All')
            excludeUsers = $BreakGlassUserIds.ToArray()
        }
    }
    grantControls = @{
        operator = 'OR'
        builtInControls = @('block')
    }
}
[void](Get-OrCreateCAPolicy -Body $caLegacyBody)

# CA03: Require compliant device for Copilot pilot
$caCompliantBody = @{
    displayName = $CA_CompliantDevice_Name
    state = 'enabledForReportingButNotEnforced'
    conditions = @{
        clientAppTypes = @('mobileAppsAndDesktopClients','browser')
        applications = @{
            includeApplications = @('All')
        }
        users = @{
            includeGroups = @($gPilot.Id)
            excludeUsers = $BreakGlassUserIds.ToArray()
        }
    }
    grantControls = @{
        operator = 'OR'
        builtInControls = @('compliantDevice','domainJoinedDevice')
    }
}
[void](Get-OrCreateCAPolicy -Body $caCompliantBody)

# CA04: Admin portal protection for IT admins
